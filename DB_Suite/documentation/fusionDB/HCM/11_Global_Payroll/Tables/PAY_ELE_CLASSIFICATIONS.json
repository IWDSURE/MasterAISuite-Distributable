{
  "name": "PAY_ELE_CLASSIFICATIONS",
  "object_type": "TABLE",
  "description": "This table contains element classifications that define groups of elements for legislative and informational needs. Primary classifications are specific to a legislation and are predefined for all supported payroll legislations. Secondary or sub-classifications are specific to a legislative group and may be predefined for a specific legislation. Secondary classifications can be associated with an element to manage taxability rules.All types of classifications have a role in creating balance feeds automatically when balances and elements are created.",
  "schema": "FUSION",
  "owner": "PAY",
  "tablespace": "REFERENCE",
