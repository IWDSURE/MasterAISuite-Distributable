          },
          "subTypes": {
            "type": "object",
            "description": "Maps discriminator values (as defined in subtypes) to query objects specific to corresponding subtypes. Subtype-specific query objects support a subset(fields,accessors,filter) of the query capabilities when compared to the base."
          },
          "accessors": {
            "type": "object",
            "description": "Maps accessor names to query objects specific to corresponding accessors. Query object for each accessor supports query capabilities similar to the base."
          }
        }
      }
