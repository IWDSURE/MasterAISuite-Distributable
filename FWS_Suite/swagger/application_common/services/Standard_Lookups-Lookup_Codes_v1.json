          {
            "type": "object",
            "properties": {
              "collection": {
                "type": "object",
                "description": "Defines query criteria that can be applied on a resource collection.",
                "properties": {
                  "filter": {
                    "type": "string",
                    "description": "The resource collection will be queried using the specified filter condition."
                  },
                  "limit": {
                    "type": "integer",
                    "description": "Restricts the number of resource items returned inside the resource collection. If the limit exceeds the resource count then the framework will only return the available resource items."
                  },
                  "offset": {
                    "type": "integer",
                    "description": "Defines the starting position of the resource collection. If offset exceeds the resource count then no resource items are returned."
                  },
                  "sortBy": {
                    "type": "array",
                    "description": "Orders a resource collection based on the specified fields.",
                    "items": {
                      "oneOf": [
                        {
                          "type": "string",
                          "description": "Name of field based on which sorting will happen. Order is ascending."
                        },
                        {
                          "type": "object",
                          "description": "Object with single entry. Key must be name of field based on which sorting will happen. Value must be either asc or desc to decide the sort order."
                        }
                      ]
                    }
                  },
                  "privilege": {
                    "type": "string",
                    "description": "Represents the privilege or action required to check for while serving a request to access a resource."
                  }
                },
                "additionalProperties": false
              }
            }
          }
        ]
      },
