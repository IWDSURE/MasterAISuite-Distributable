  "paths": {
    "<servername>/api/fusion-ai/orchestrator/a2a/v1/{workflowCode}/.well-known/agent.json": {
      "get": {
        "tags": [
          "Fusion AI Agent-to-Agent API/Agent Card"
        ],
        "summary": "Get agent card",
        "description": "Retrieve the A2A agent card for a published workflow identified by workflow code.",
        "operationId": "getAgentCard",
        "parameters": [
          {
            "name": "workflowCode",
            "in": "path",
            "description": "Published workflow code.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Agent card retrieved.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentCard"
                }
              }
            }
          },
          "404": {
            "description": "Workflow not found.",
            "content": {}
          }
        },
        "x-internal-id": "<servername>-api-fusion-ai-orchestrator-a2a-v1-{workflowCode}-.well-known-agent.json-get",
        "x-filename-id": "servername-api-fusion-ai-orchestrator-a2a-v1-workflowcode-well-known-agent-json-get"
      }
    }
  },
