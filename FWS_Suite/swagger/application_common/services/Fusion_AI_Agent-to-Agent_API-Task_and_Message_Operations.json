  "paths": {
    "<servername>/api/fusion-ai/orchestrator/a2a/v1/{workflowCode}": {
      "post": {
        "tags": [
          "Fusion AI Agent-to-Agent API/Task and Message Operations"
        ],
        "summary": "Send task, send message, or get task",
        "description": "Execute a JSON-RPC operation against a published workflow. Supported methods are `tasks/send`, `message/send`, and `tasks/get`.",
        "operationId": "invokeAgentOperation",
        "parameters": [
          {
            "name": "workflowCode",
            "in": "path",
            "description": "Published workflow code.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "JSON-RPC request for task send, message send, or task retrieval.",
          "content": {
            "application/json": {
              "schema": {
                "oneOf": [
                  {
                    "$ref": "#/components/schemas/SendTaskJSONRPCRequest"
                  },
                  {
                    "$ref": "#/components/schemas/SendMessageJSONRPCRequest"
                  },
                  {
                    "$ref": "#/components/schemas/GetTaskJSONRPCRequest"
                  }
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Operation completed or task state retrieved.",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "$ref": "#/components/schemas/TaskResponse"
                    },
                    {
                      "$ref": "#/components/schemas/SendMessageResponse"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid request or unsupported JSON-RPC method.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Workflow not found.",
            "content": {}
          }
        },
        "x-codegen-request-body-name": "body",
        "x-internal-id": "<servername>-api-fusion-ai-orchestrator-a2a-v1-{workflowCode}-post",
        "x-filename-id": "servername-api-fusion-ai-orchestrator-a2a-v1-workflowcode-post"
      }
    }
  },
