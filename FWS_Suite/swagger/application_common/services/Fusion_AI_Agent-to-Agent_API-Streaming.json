  "servers": [],
  "paths": {
    "<servername>/api/fusion-ai/orchestrator/a2a/v1/{workflowCode}/stream": {
      "post": {
        "tags": [
          "Fusion AI Agent-to-Agent API/Streaming"
        ],
        "summary": "Stream message response",
        "description": "Start a streaming message invocation for a published workflow. The request method must be `message/stream`. The response is returned as Server-Sent Events whose event payloads contain JSON-RPC task updates.",
        "operationId": "streamAgentRequest",
        "parameters": [
          {
            "name": "workflowCode",
            "in": "path",
            "description": "Published workflow code.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "JSON-RPC stream message request.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StreamMessageJSONRPCRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Streaming task events started.",
            "content": {
              "text/event-stream": {
                "schema": {
                  "$ref": "#/components/schemas/SendMessageResponse"
                }
              }
            }
          },
          "404": {
            "description": "Workflow not found.",
            "content": {}
          }
        },
        "x-codegen-request-body-name": "body",
        "x-internal-id": "<servername>-api-fusion-ai-orchestrator-a2a-v1-{workflowCode}-stream-post",
        "x-filename-id": "servername-api-fusion-ai-orchestrator-a2a-v1-workflowcode-stream-post"
      }
    }
  },
